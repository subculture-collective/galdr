# GitHub personal access token
GH_TOKEN=

# OpenCode service auth. Used by the sandbox-local OpenCode HTTP server.
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=

# Optional exact OpenCode model IDs per Sandcastle role.
# Leave blank to use OpenCode service defaults.
SANDCASTLE_OPENCODE_PLANNER_MODEL=
SANDCASTLE_OPENCODE_IMPLEMENTER_MODEL=
SANDCASTLE_OPENCODE_REVIEWER_MODEL=
SANDCASTLE_OPENCODE_MERGER_MODEL=

# Legacy/provider-specific: only needed if your OpenCode config still uses
# API-key-backed providers. Sandcastle itself does not require this.
OPENCODE_API_KEY=

OPENAI_AUTH_TYPE="oauth"
OPENAI_AUTH_REFRESH=
OPENAI_AUTH_ACCESS=
OPENAI_AUTH_EXPIRES=
OPENAI_AUTH_ACCOUNT_ID=

COPILOT_AUTH_TYPE="oauth"
COPILOT_AUTH_ACCESS=
COPILOT_AUTH_REFRESH=
COPILOT_AUTH_EXPIRES=0
