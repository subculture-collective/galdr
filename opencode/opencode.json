{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini",
  "mcp": {
    "github": {
      "type": "local",
      "command": ["/home/onnwee/.agents/scripts/github_mcp_stdio.sh"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest", "--isolated", "--headless"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--isolated",
        "--headless",
        "--no-usage-statistics"
      ],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  },
  "plugin": ["opencode-agent-skills"],
  "permission": "allow",
  "compaction": {
    "auto": false,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".next/**",
      ".turbo/**",
      "coverage/**",
      ".git/**",
      ".venv/**",
      "vendor/**"
    ]
  },
  "instructions": [
    "AGENTS.md",
    "README.md",
    "docs/**/*.md",
    ".opencode/rules/**/*.md",
    "~/.config/opencode/plugin/shell-strategy/shell_strategy.md"
  ],
  "share": "manual"
}
